rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /accounts/{document=**} {
      allow read, write: if true;
    }
    match /subscriptions/{document=**} {
      allow read, write: if true;
    }
    match /config/{document=**} {
      allow read, write: if true;
    }
  }
}
