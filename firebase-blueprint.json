{
  "collections": [
    {
      "name": "accounts",
      "rules": [
        {
          "allow": ["read", "write"],
          "condition": "false"
        }
      ],
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "targetDate": { "type": "string" },
          "reminder10MinSent": { "type": "boolean" },
          "readySent": { "type": "boolean" }
        }
      }
    },
    {
      "name": "subscriptions",
      "rules": [
        {
          "allow": ["read", "write"],
          "condition": "false"
        }
      ],
      "schema": {
        "type": "object"
      }
    }
  ]
}
